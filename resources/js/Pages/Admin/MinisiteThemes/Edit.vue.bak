const form = reactive({
  name: '',
  slug: '',
  description: '',
  preview_image: '',
  is_active: true,
  css_variables: { ...defaultCssVariables },
  layout_config: { ...defaultLayoutConfig },
  section_config: { ...defaultSectionConfig },
})

const initForm = () => {
  if (theme.value) {
    form.name = theme.value.name
    form.slug = theme.value.slug
    form.description = theme.value.description || ''
    form.preview_image = theme.value.preview_image || ''
    form.is_active = theme.value.is_active
    form.css_variables = {
      ...defaultCssVariables,
      ...theme.value.css_variables,
      colors: { ...defaultCssVariables.colors, ...(theme.value.css_variables?.colors || {}) },
      fonts: { ...defaultCssVariables.fonts, ...(theme.value.css_variables?.fonts || {}) },
    }
    form.layout_config = { ...defaultLayoutConfig, ...(theme.value.layout_config || {}) }
    form.section_config = {
      ...defaultSectionConfig,
      ...(theme.value.section_config || {}),
      section_variants: {
        ...defaultSectionConfig.section_variants,
        ...(theme.value.section_config?.section_variants || {}),
      },
      section_schemes: {
        ...defaultSectionConfig.section_schemes,
        ...(theme.value.section_config?.section_schemes || {}),
      },
      header_colors: {
        ...defaultSectionConfig.header_colors,
        ...(theme.value.section_config?.header_colors || {}),
      },
      footer_colors: {
        ...defaultSectionConfig.footer_colors,
        ...(theme.value.section_config?.footer_colors || {}),
      },
    }
  }
}

initForm()

const getButtonsBorderRadius = (style) => {
  const radius = {
    rounded: '50px',
    square: '0px',
    round: '8px',
  }
  return radius[style] || '8px'
}

const getCardBorderRadius = (style) => {
  const radius = {
    rounded: '50px',
    square: '0px',
    round: '12px',
  }
  return radius[style] || '12px'
}

const getPreviewStyle = () => {
  return {
    '--preview-primary': form.css_variables.colors.brand_primary || '#1a1a2e',
    '--preview-secondary': form.css_variables.colors.brand_secondary || '#6B7280',
    '--preview-accent': form.css_variables.colors.brand_accent || '#3B82F6',
    backgroundColor: form.css_variables.colors.brand_background || '#f8f9fa',
  }
}

const setSectionVariant = (section, variant) => {
  if (!form.section_config.section_variants) {
    form.section_config.section_variants = { ...defaultSectionConfig.section_variants }
  }
  form.section_config.section_variants[section] = variant
}

const getSchemePreviewStyle = (schemeName) => {
  if (schemeName === selectedSchemeKey.value) {
    const scheme = editingScheme
    const colors = form.css_variables.colors
    const resolveColor = (c) => c.startsWith('#') || c.startsWith('rgba') || c === 'transparent' ? c : colors[c] || c

    let bg = resolveColor(scheme.bg)
    if (scheme.is_gradient) {
      bg = `linear-gradient(${resolveColor(scheme.bg_start)}, ${resolveColor(scheme.bg_end)})`
    } else if (scheme.bg === 'transparent') {
      bg = '#f8f9fa'
    }

    return {
      background: bg,
      color: resolveColor(scheme.text),
      border: `1px solid ${resolveColor(scheme.border)}`,
    }
  }

  const customPalette = form.section_config.scheme_palettes?.[schemeName]
  if (customPalette) {
    const bg = customPalette.is_gradient
      ? `linear-gradient(${customPalette.bg_start}, ${customPalette.bg_end})`
      : (customPalette.bg === 'transparent' ? '#f8f9fa' : customPalette.bg)
    return {
      background: bg,
      color: customPalette.text,
      border: customPalette.border !== 'transparent' ? `1px solid ${customPalette.border}` : '1px solid #e5e7eb',
    }
  }

  const scheme = schemeDefinitions[schemeName]
  if (!scheme) return {}

  const colors = form.css_variables.colors

  const bgType = scheme.bg_type
  let bg = scheme.bg
  if (bgType === 'gradient') {
    const startColor = scheme.bg_start.startsWith('#') ? scheme.bg_start : colors[scheme.bg_start] || scheme.bg_start
    const endColor = scheme.bg_end.startsWith('#') ? scheme.bg_end : colors[scheme.bg_end] || scheme.bg_end
    bg = `linear-gradient(${startColor}, ${endColor})`
  } else if (bg === 'transparent') {
    bg = '#f8f9fa'
  } else if (!bg.startsWith('#') && !bg.startsWith('rgba')) {
    bg = colors[bg] || bg
  }

  const textColor = scheme.text.startsWith('#') || scheme.text.startsWith('rgba') ? scheme.text : colors[scheme.text] || scheme.text
  const borderColor = scheme.border === 'transparent' ? '#e5e7eb' : (scheme.border.startsWith('#') || scheme.border.startsWith('rgba') ? scheme.border : colors[scheme.border] || scheme.border)

  return {
    background: bg,
    color: textColor,
    border: `1px solid ${borderColor}`,
  }
}

const getButtonPreviewStyle = (schemeKey) => {
  if (schemeKey === selectedSchemeKey.value) {
    const colors = form.css_variables.colors
    const resolveColor = (c) => c.startsWith('#') || c.startsWith('rgba') ? c : colors[c] || c
    return {
      backgroundColor: resolveColor(editingScheme.button_bg),
      color: resolveColor(editingScheme.button_text),
      borderColor: resolveColor(editingScheme.button_border),
    }
  }

  const customPalette = form.section_config.scheme_palettes?.[schemeKey]
  if (customPalette) {
    return {
      backgroundColor: customPalette.button_bg || '#ffffff',
      color: customPalette.button_text || '#374151',
      borderColor: customPalette.button_border || 'rgba(0,0,0,0.1)',
    }
  }
  const scheme = schemeDefinitions[schemeKey]
  if (!scheme) return {}

  const colors = form.css_variables.colors
  const resolveColor = (c) => c.startsWith('#') || c.startsWith('rgba') ? c : colors[c] || c

  return {
    backgroundColor: resolveColor(scheme.button_bg),
    color: resolveColor(scheme.button_text),
    borderColor: resolveColor(scheme.button_border),
  }
}

