  if (c.startsWith('#') || c.startsWith('rgba') || c === 'transparent') return c
  return form.css_variables.colors[c] || c
}

const getAllSchemesPreview = () => {
  return ['hero', 'primary', 'secondary', 'accent', 'light', 'neutral', 'dark', 'transparent', 'gradient'].map(name => ({
    name,
    style: getSchemePreviewStyle(name)
  }))
}

const schemeList = [
  { key: 'primary', label: 'Primary' },
  { key: 'secondary', label: 'Secondary' },
  { key: 'accent', label: 'Accent' },
  { key: 'light', label: 'Light' },
  { key: 'neutral', label: 'Neutral' },
  { key: 'dark', label: 'Dark' },
  { key: 'transparent', label: 'Transparent' },
  { key: 'gradient', label: 'Gradient' },
  { key: 'header', label: 'Header' },
  { key: 'footer', label: 'Footer' },
]

const selectedSchemeKey = ref('primary')

const isHeaderOrFooter = computed(() => ['header', 'footer'].includes(selectedSchemeKey.value))

const editingScheme = reactive({
  bg: 'white',
  bg_start: 'brand_primary',
  bg_end: 'brand_secondary',
  text: 'brand_text',
  heading: 'brand_primary',
  link: 'brand_primary',
  icon: 'brand_primary',
  border: 'rgba(0,0,0,0.1)',
  card_bg: 'white',
  card_text: 'brand_text',
  card_heading: 'brand_primary',
  card_border: 'rgba(0,0,0,0.1)',
  button_bg: 'brand_primary',
  button_text: 'white',
  button_border: 'brand_primary',
  button_hover_bg: 'brand_text',
  button_hover_text: 'white',
  shadow_color: 'rgba(0,0,0,0.1)',
  divider_color: 'rgba(0,0,0,0.1)',
  is_gradient: false,
  nav_bg: 'white',
  nav_text: 'brand_text',
  nav_link: 'brand_primary',
  nav_link_hover: 'brand_accent',
  nav_border: 'rgba(0,0,0,0.1)',
  link_hover: 'brand_accent',
})

const loadSchemeForEditing = (schemeKey) => {
  if (schemeKey === 'header') {
    Object.assign(editingScheme, form.section_config.header_colors)
    return
  }
  if (schemeKey === 'footer') {
    Object.assign(editingScheme, form.section_config.footer_colors)
    return
  }

  const customPalette = form.section_config.scheme_palettes?.[schemeKey]
  if (customPalette) {
    Object.assign(editingScheme, customPalette)
  } else {
    const def = schemeDefinitions[schemeKey]
    if (def) {
      editingScheme.bg = def.bg
      editingScheme.bg_start = def.bg_start
      editingScheme.bg_end = def.bg_end
      editingScheme.text = def.text
      editingScheme.heading = def.heading
      editingScheme.link = def.link
      editingScheme.icon = def.icon
      editingScheme.border = def.border
      editingScheme.card_bg = def.card_bg
      editingScheme.card_text = def.card_text
      editingScheme.card_heading = def.card_heading
      editingScheme.card_border = def.card_border
      editingScheme.button_bg = def.button_bg
      editingScheme.button_text = def.button_text
      editingScheme.button_border = def.button_border
      editingScheme.button_hover_bg = def.button_hover_bg
      editingScheme.button_hover_text = def.button_hover_text
      editingScheme.shadow_color = def.shadow_color || 'rgba(0,0,0,0.15)'
      editingScheme.divider_color = def.divider_color || 'rgba(255,255,255,0.2)'
      editingScheme.is_gradient = def.bg_type === 'gradient'
      editingScheme.nav_bg = def.nav_bg
      editingScheme.nav_text = def.nav_text
      editingScheme.nav_link = def.nav_link
      editingScheme.nav_link_hover = def.nav_link_hover
      editingScheme.nav_border = def.nav_border
    }
  }
}

const saveSchemeColors = () => {
  if (selectedSchemeKey.value === 'header') {
    form.section_config.header_colors = { ...editingScheme }
    toast.success('Colores del header guardados')
    return
  }
  if (selectedSchemeKey.value === 'footer') {
    form.section_config.footer_colors = { ...editingScheme }
    toast.success('Colores del footer guardados')
    return
  }

  if (!form.section_config.scheme_palettes) {
    form.section_config.scheme_palettes = {}
  }
  form.section_config.scheme_palettes[selectedSchemeKey.value] = { ...editingScheme }
  toast.success('Colores del scheme guardados')
}

const getSchemePreviewBg = (schemeKey) => {
  const customPalette = form.section_config.scheme_palettes?.[schemeKey]
  if (customPalette) {
    if (customPalette.is_gradient) {
      return `linear-gradient(${customPalette.bg_start}, ${customPalette.bg_end})`
    }
    return customPalette.bg
  }
  const def = schemeDefinitions[schemeKey]
  if (!def) return '#6B7280'

  const colors = form.css_variables.colors
  const resolveColor = (c) => c.startsWith('#') || c.startsWith('rgba') ? c : colors[c] || c

  if (def.bg_type === 'gradient') {
    return `linear-gradient(${resolveColor(def.bg_start)}, ${resolveColor(def.bg_end)})`
  }
  const bg = def.bg === 'transparent' ? '#f8f9fa' : resolveColor(def.bg)
  return bg
}

const getSelectedSchemeBg = () => {
  if (editingScheme.is_gradient) {
    return `linear-gradient(${editingScheme.bg_start}, ${editingScheme.bg_end})`
  }
  return editingScheme.bg
}

const getSelectedSchemeText = () => editingScheme.text

watch(selectedSchemeKey, (newVal) => {
  loadSchemeForEditing(newVal)
})

onMounted(() => {
  loadSchemeForEditing(selectedSchemeKey.value)
})

const submitForm = () => {
  sending.value = true

  router.put(`/admin/minisite-themes/${theme.value.id}`, form, {
    onSuccess: () => {
      sending.value = false
      toast.success('Theme actualizado correctamente')
    },
    onError: () => {
      sending.value = false
      toast.error('Error al guardar el theme')
    },
    onFinish: () => {
      sending.value = false
    },
  })
}
</script>

